    .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .card { padding: 26px; border-radius: var(--radius); border: 1px solid var(--stroke); background: linear-gradient(145deg, rgba(255,255,255,.11), rgba(255,255,255,.04)); backdrop-filter: blur(24px); box-shadow: 0 18px 45px rgba(0,0,0,.20); }
