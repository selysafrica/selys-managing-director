    .card h3 { margin: 0 0 10px; font-size: 22px; letter-spacing: -.025em; }
    .card p, .card li { color: var(--muted); line-height: 1.62; font-size: 15px; }
    ul { margin: 12px 0 0; padding-left: 20px; } li { margin: 8px 0; }
    .timeline { display: grid; gap: 14px; counter-reset: step; }
    .step { display: grid; grid-template-columns: 64px 1fr; gap: 16px; padding: 20px; border-radius: 26px; border: 1px solid var(--stroke); background: rgba(255,255,255,.06); backdrop-filter: blur(20px); }
    .step::before { counter-increment: step; content: counter(step); width: 54px; height: 54px; border-radius: 18px; display: grid; place-items: center; font-weight: 1000; color: #031314; background: linear-gradient(145deg, var(--aqua), var(--teal)); }
    .step h3 { margin: 0 0 6px; } .step p { margin: 0; color: var(--muted); line-height: 1.55; }
    .apply-wrap { display: grid; grid-template-columns: 1fr .86fr; gap: 22px; align-items: stretch; }
    form { display: grid; gap: 14px; }
    input, textarea, select { width: 100%; padding: 16px; border-radius: 18px; border: 1px solid rgba(255,255,255,.16); background: rgba(255,255,255,.07); color: var(--white); outline: none; font: inherit; }
    input::placeholder, textarea::placeholder { color: rgba(247,255,253,.44); }
    textarea { min-height: 130px; resize: vertical; }
    .notice { color: rgba(247,255,253,.6); font-size: 13px; line-height: 1.5; }
    .form-status { display: none; padding: 14px; border-radius: 16px; line-height: 1.45; }
    .form-status.success { display: block; background: rgba(84,221,212,.12); border: 1px solid rgba(84,221,212,.35); }
    .form-status.error { display: block; background: rgba(255,80,80,.12); border: 1px solid rgba(255,80,80,.35); }
    .contact-card { display: flex; flex-direction: column; justify-content: space-between; min-height: 100%; }
    .contact-list { display: grid; gap: 12px; margin-top: 22px; }
    .contact-item { padding: 15px; border-radius: 20px; background: rgba(255,255,255,.065); border: 1px solid rgba(255,255,255,.11); color: var(--muted); }
