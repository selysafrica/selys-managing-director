      mask-image: radial-gradient(circle at center, black, transparent 78%); z-index: 0;
    }
    .blob { position: fixed; width: 340px; height: 340px; border-radius: 50%; filter: blur(70px); opacity: .28; z-index: 0; animation: float 9s ease-in-out infinite; }
    .blob.one { background: var(--aqua); left: -120px; top: 220px; }
    .blob.two { background: var(--gold); right: -140px; top: 520px; animation-delay: -3s; }
    @keyframes float { 0%,100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-28px) scale(1.08); } }
    .container { width: min(1180px, 92%); margin: 0 auto; position: relative; z-index: 2; }
    nav { height: 86px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 20; backdrop-filter: blur(22px); }
    .brand { display: flex; align-items: center; gap: 12px; font-weight: 900; letter-spacing: .16em; font-size: 13px; text-transform: uppercase; }
    .logo { width: 42px; height: 42px; border-radius: 15px; background: linear-gradient(145deg, var(--aqua), var(--teal)); display: grid; place-items: center; color: #031314; font-weight: 1000; box-shadow: 0 0 34px rgba(84,221,212,.34); }
    .nav-links { display: flex; gap: 10px; align-items: center; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 750; padding: 11px 14px; border-radius: 999px; transition: .25s ease; }
    .nav-links a:hover { color: var(--white); background: rgba(255,255,255,.07); }
    .apply-mini { color: #031314 !important; background: linear-gradient(145deg, var(--aqua), var(--teal)) !important; font-weight: 900 !important; box-shadow: 0 14px 32px rgba(84,221,212,.18); }
    .hero { min-height: calc(100vh - 86px); display: grid; grid-template-columns: 1.08fr .92fr; gap: 38px; align-items: center; padding: 46px 0 78px; }
    .kicker { display: inline-flex; align-items: center; gap: 9px; color: var(--aqua); font-size: 12px; font-weight: 900; letter-spacing: .18em; text-transform: uppercase; padding: 10px 14px; border: 1px solid rgba(84,221,212,.28); background: rgba(84,221,212,.08); border-radius: 999px; }
    .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--aqua); animation: pulse 2s infinite; }
    @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(84,221,212,.72); } 70% { box-shadow: 0 0 0 11px rgba(84,221,212,0); } 100% { box-shadow: 0 0 0 0 rgba(84,221,212,0); } }
    h1 { font-size: clamp(48px, 8vw, 92px); line-height: .88; margin: 24px 0 22px; letter-spacing: -.075em; max-width: 840px; }
    .hero p { color: var(--muted); font-size: 19px; line-height: 1.62; max-width: 760px; margin: 0; }
    .cta-row { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 32px; }
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 9px; min-height: 54px; padding: 15px 22px; border-radius: 18px; text-decoration: none; font-weight: 900; color: var(--white); border: 1px solid var(--stroke); background: rgba(255,255,255,.08); backdrop-filter: blur(18px); transition: .25s ease; cursor: pointer; }
