  <script>
    const form = document.getElementById('applicationForm');
    const statusBox = document.getElementById('formStatus');
    const submitBtn = document.getElementById('submitBtn');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Envoi en cours...';

      try {
        const response = await fetch('/api/apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: document.getElementById('name').value,
            email: document.getElementById('email').value,
            phone: document.getElementById('phone').value,
            experience: document.getElementById('experience').value,
            message: document.getElementById('message').value,
          }),
        });

        const data = await response.json();
        if (!response.ok) throw new Error(data.message);

        statusBox.className = 'form-status success';
        statusBox.textContent = 'Candidature envoyée avec succès. Merci pour votre intérêt pour SELYS AFRICA.';
        form.reset();
      } catch (err) {
        statusBox.className = 'form-status error';
        statusBox.textContent = err.message || "Erreur lors de l'envoi. Veuillez réessayer.";
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Envoyer ma candidature';
      }
    });
  </script>
