    .btn.gold { background: rgba(215,181,109,.14); border-color: rgba(215,181,109,.38); }
    .glass-panel { position: relative; border: 1px solid var(--stroke); background: linear-gradient(145deg, rgba(255,255,255,.14), rgba(255,255,255,.04)), radial-gradient(circle at top, rgba(84,221,212,.16), transparent 45%); backdrop-filter: blur(30px); border-radius: 38px; box-shadow: var(--shadow); overflow: hidden; }
    .hero-panel { padding: 28px; }
    .country { width: 86px; height: 86px; border-radius: 26px; display: grid; place-items: center; font-size: 42px; background: rgba(255,255,255,.09); border: 1px solid rgba(255,255,255,.16); }
